# Database (Supabase or any Postgres)
# For Supabase: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/loglens

# API authentication key — change this in production!
API_KEY=dev-secret-key

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
