# =============================================================================
# LogLens Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# Supabase (recommended for production):
#   postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Local development:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/loglens
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/loglens

# -----------------------------------------------------------------------------
# API Authentication (required)
# -----------------------------------------------------------------------------
# Secret key used to authenticate SDK and API requests via the X-API-Key header.
# Generate a strong random value for production (e.g. `openssl rand -hex 32`).
API_KEY=dev-secret-key

# -----------------------------------------------------------------------------
# CORS (required for production)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for cross-origin requests.
# Set this to your Vercel frontend URL in production.
#   e.g. https://loglens.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
