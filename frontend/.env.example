# =============================================================================
# LogLens Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# API URL (required)
# -----------------------------------------------------------------------------
# The base URL of the LogLens API backend (no trailing slash).
# Local development: http://localhost:8000
# Production (Vercel): https://loglens-api.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Backend API key (required, server-only — no NEXT_PUBLIC_ prefix)
# -----------------------------------------------------------------------------
# Used by the /api proxy route to authenticate against the backend.
# Must match the backend's API_KEY. Never exposed to the browser.
LOGLENS_API_KEY=
