# =============================================================================
# LogLens Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# API URL (required)
# -----------------------------------------------------------------------------
# The base URL of the LogLens API backend (no trailing slash).
# Local development: http://localhost:8000
# Production (Render): https://loglens-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
